# Root environment file for Docker Compose
# Copy this file to .env and update with your values

# Environment Configuration
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO

# Backend Configuration
HOST=0.0.0.0
PORT=5000
DATABASE_PATH=todos.db
SECRET_KEY=your-secret-key-here-change-in-production

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:5000/api

# Security Configuration (Task 9.1: HTTPS Enforcement)
# In production, set ENVIRONMENT=production to enforce HTTPS
# and enable HSTS headers

# Security Configuration (Task 9.2: Secure Cookies)
# Session cookies are automatically configured with:
# - HTTP-only flag (prevents JavaScript access)
# - Secure flag (HTTPS only in production)
# - SameSite=Strict (CSRF protection)

# Security Configuration (Task 9.3: CORS)
# CORS is configured to allow the FRONTEND_URL domain
# In production, update FRONTEND_URL to your domain

# Security Configuration (Task 9.5: Security Logging)
# All authentication events are logged:
# - Failed login attempts with IP address
# - Rate limit triggers
# - CSRF failures
# - Unauthorized access attempts
# Logs do not contain sensitive data (passwords, tokens)

# Production Configuration (uncomment and update for production)
# ENVIRONMENT=production
# DEBUG=False
# LOG_LEVEL=WARNING
# SECRET_KEY=<generate-with-openssl-rand-hex-32>
# FRONTEND_URL=https://yourdomain.com
# VITE_API_URL=https://yourdomain.com/api
# DATABASE_PATH=/var/lib/app/todos.db
